import java.sql.*;

public class JdbcCrudDemo {

    // Database credentials
    static final String JDBC_URL = "jdbc:mysql://javadb.czuyiag0y251.ap-south-1.rds.amazonaws.com:3306/companydb";
    static final String JDBC_USER = "admin";
    static final String JDBC_PASS = "admin123";

    public static void main(String[] args) {

        Connection conn = null;
        PreparedStatement pstmt = null;
        Statement stmt = null;
        ResultSet rs = null;

        try {

            // Load MySQL JDBC Driver
            Class.forName("com.mysql.cj.jdbc.Driver");

            // Connect to AWS RDS
            conn = DriverManager.getConnection(JDBC_URL, JDBC_USER, JDBC_PASS);

            System.out.println("=================================");
            System.out.println("Connected to AWS RDS Successfully");
            System.out.println("=================================");

            // -------------------------------
            // CREATE (INSERT)
            // -------------------------------

            String insertQuery =
                    "INSERT INTO employees(name,email,country,salary) VALUES(?,?,?,?)";

            pstmt = conn.prepareStatement(insertQuery);

            pstmt.setString(1, "Alice");
            pstmt.setString(2, "alice@example.com");
            pstmt.setString(3, "USA");
            pstmt.setDouble(4, 50000);

            int rows = pstmt.executeUpdate();

            if (rows > 0) {
                System.out.println("\nEmployee inserted successfully.");
            }

            // -------------------------------
            // READ (SELECT)
            // -------------------------------

            stmt = conn.createStatement();

            rs = stmt.executeQuery("SELECT * FROM employees");

            System.out.println("\nEmployee Records");
            System.out.println("---------------------------------------------------------------");
            System.out.printf("%-5s %-15s %-25s %-12s %-10s%n",
                    "ID", "NAME", "EMAIL", "COUNTRY", "SALARY");
            System.out.println("---------------------------------------------------------------");

            while (rs.next()) {

                System.out.printf("%-5d %-15s %-25s %-12s %-10.2f%n",
                        rs.getInt("id"),
                        rs.getString("name"),
                        rs.getString("email"),
                        rs.getString("country"),
                        rs.getDouble("salary"));
            }

            // -------------------------------
            // UPDATE
            // -------------------------------

            String updateQuery =
                    "UPDATE employees SET salary=? WHERE name=?";

            pstmt = conn.prepareStatement(updateQuery);

            pstmt.setDouble(1, 60000);
            pstmt.setString(2, "Alice");

            rows = pstmt.executeUpdate();

            if (rows > 0) {
                System.out.println("\nEmployee salary updated successfully.");
            }

            // -------------------------------
            // DELETE
            // -------------------------------

            String deleteQuery =
                    "DELETE FROM employees WHERE name=?";

            pstmt = conn.prepareStatement(deleteQuery);

            pstmt.setString(1, "Alice");

            rows = pstmt.executeUpdate();

            if (rows > 0) {
                System.out.println("Employee deleted successfully.");
            }

            System.out.println("\nCRUD Operations Completed Successfully.");

        } catch (Exception e) {

            e.printStackTrace();

        } finally {

            try {
                if (rs != null)
                    rs.close();

                if (stmt != null)
                    stmt.close();

                if (pstmt != null)
                    pstmt.close();

                if (conn != null)
                    conn.close();

                System.out.println("Database Connection Closed.");

            } catch (SQLException e) {

                e.printStackTrace();
            }
        }
    }
}
